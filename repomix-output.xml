<script>
/* ── Chart type data ──────────────────────────────────────── */
const CHART_GROUPS = [
  { name: "Column", icon: "📊", items: [
    { key: "bar", label: "Bar Chart" },
    { key: "stacked_bar", label: "Stacked Bar" },
    { key: "lollipop", label: "Lollipop" },
    { key: "waterfall", label: "Waterfall" },
  ]},
  { name: "XY", icon: "📈", items: [
    { key: "line", label: "Line Graph" },
    { key: "scatter", label: "Scatter Plot" },
    { key: "area_chart", label: "Area Chart" },
    { key: "curve_fit", label: "Curve Fit" },
    { key: "bubble", label: "Bubble Chart" },
  ]},
  { name: "Grouped", icon: "📋", items: [
    { key: "grouped_bar", label: "Grouped Bar" },
    { key: "two_way_anova", label: "Two-Way ANOVA" },
    { key: "contingency", label: "Contingency" },
  ]},
  { name: "Distribution", icon: "🔔", items: [
    { key: "box", label: "Box Plot" },
    { key: "violin", label: "Violin Plot" },
    { key: "histogram", label: "Histogram" },
    { key: "dot_plot", label: "Dot Plot" },
    { key: "raincloud", label: "Raincloud" },
    { key: "qq_plot", label: "Q-Q Plot" },
    { key: "ecdf", label: "ECDF" },
  ]},
  { name: "Survival", icon: "📉", items: [
    { key: "kaplan_meier", label: "Survival Curve" },
  ]},
  { name: "Correlation", icon: "🔗", items: [
    { key: "bland_altman", label: "Bland-Altman" },
    { key: "heatmap", label: "Heatmap" },
  ]},
  { name: "Other", icon: "✨", items: [
    { key: "before_after", label: "Before / After" },
    { key: "repeated_measures", label: "Repeated Meas." },
    { key: "subcolumn_scatter", label: "Subcolumn" },
    { key: "column_stats", label: "Col Statistics" },
    { key: "chi_square_gof", label: "Chi-Sq GoF" },
    { key: "forest_plot", label: "Forest Plot" },
    { key: "pyramid", label: "Pyramid" },
  ]},
];

/* ── Build sidebar ────────────────────────────────────────── */
const sidebar = document.getElementById("sidebar");
let activeItem = null;

CHART_GROUPS.forEach(group => {
  const groupDiv = document.createElement("div");
  groupDiv.className = "sidebar-group";

  const header = document.createElement("div");
  header.className = "sidebar-group-header";
  header.innerHTML = `<span class="arrow">▾</span> ${group.icon} ${group.name}`;
  header.addEventListener("click", () => {
    header.classList.toggle("collapsed");
  });
  groupDiv.appendChild(header);

  const items = document.createElement("div");
  items.className = "sidebar-items";
  group.items.forEach(item => {
    const el = document.createElement("div");
    el.className = "sidebar-item";
    if (item.key === "bar") { el.classList.add("active"); activeItem = el; }
    el.innerHTML = `<span class="icon">${group.icon}</span> ${item.label}`;
    el.addEventListener("click", () => {
      if (activeItem) activeItem.classList.remove("active");
      el.classList.add("active");
      activeItem = el;
    });
    items.appendChild(el);
  });
  groupDiv.appendChild(items);
  sidebar.appendChild(groupDiv);
});

/* ── Tab switching ────────────────────────────────────────── */
document.querySelectorAll(".tab-bar button").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".tab-bar button").forEach(b => b.classList.remove("active"));
    document.querySelectorAll(".tab-pane").forEach(p => p.classList.remove("active"));
    btn.classList.add("active");
    document.getElementById("tab-" + btn.dataset.tab).classList.add("active");
  });
});

/* ── Results strip toggle ─────────────────────────────────── */
function toggleResults() {
  const header = document.getElementById("resultsHeader");
  const body = document.getElementById("resultsBody");
  header.classList.toggle("expanded");
  body.classList.toggle("open");
}

/* ── Help panel toggle ────────────────────────────────────── */
function toggleHelp() {
  document.getElementById("helpOverlay").classList.toggle("visible");
  document.getElementById("helpPanel").classList.toggle("visible");
}

/* ── Render demo chart ────────────────────────────────────── */
function renderChart() {
  const title = document.getElementById("titleInput").value || "Treatment Response";
  const groups = ["Control", "Drug A", "Drug B"];
  const means = [5.2, 8.7, 12.1];
  const sems = [0.8, 1.1, 0.9];
  const colors = ["#E8453C", "#2274A5", "#32936F"];

  // Jittered individual data points
  const allX = [], allY = [], allColors = [];
  const rng = (seed) => { let s = seed; return () => { s = (s * 16807) % 2147483647; return s / 2147483647; }; };
  groups.forEach((g, gi) => {
    const r = rng(42 + gi * 100);
    for (let i = 0; i < 10; i++) {
      allX.push(g);
      allY.push(means[gi] + (r() - 0.5) * sems[gi] * 5);
      allColors.push(colors[gi]);
    }
  });

  const traces = groups.map((g, i) => ({
    type: "bar",
    name: g,
    x: [g],
    y: [means[i]],
    error_y: { type: "data", array: [sems[i]], visible: true, thickness: 1.5, width: 4 },
    marker: { color: colors[i], opacity: 0.85, line: { width: 1, color: colors[i].replace(/[0-9a-f]{2}$/i, '80') } },
    width: 0.55,
    showlegend: false,
  }));

  // Add jittered points
  traces.push({
    type: "scatter",
    mode: "markers",
    x: allX,
    y: allY,
    marker: { color: allColors, size: 6, opacity: 0.7, line: { width: 0.5, color: "#333" } },
    showlegend: false,
    hoverinfo: "y",
  });

  const layout = {
    title: { text: title, font: { family: "Arial", size: 16, color: "#1a1a1a" }, x: 0.5 },
    xaxis: {
      title: { text: "Treatment Group", font: { family: "Arial", size: 13 }, standoff: 10 },
      showline: true, linewidth: 1, linecolor: "#333",
      showgrid: false, zeroline: false,
      tickfont: { family: "Arial", size: 12 },
    },
    yaxis: {
      title: { text: "Response (mg/dL)", font: { family: "Arial", size: 13 }, standoff: 10 },
      showline: true, linewidth: 1, linecolor: "#333",
      showgrid: false, zeroline: false,
      tickfont: { family: "Arial", size: 12 },
      ticks: "outside", ticklen: 5,
      range: [0, 18],
    },
    plot_bgcolor: "white",
    paper_bgcolor: "white",
    font: { family: "Arial" },
    margin: { l: 60, r: 30, t: 50, b: 50 },
    // Prism open-spine: hide top and right borders
    shapes: [],
    annotations: [
      // Significance brackets
      { x: "Control", y: 14.5, xref: "x", yref: "y", text: "", showarrow: false },
      {
        x: 0.167, y: 0.88, xref: "paper", yref: "paper",
        text: "**", font: { size: 14, color: "#E8453C" }, showarrow: false,
      },
      {
        x: 0.5, y: 0.95, xref: "paper", yref: "paper",
        text: "***", font: { size: 14, color: "#E8453C" }, showarrow: false,
      },
    ],
  };

  const config = {
    responsive: true,
    displayModeBar: true,
    modeBarButtonsToRemove: ["lasso2d", "select2d", "autoScale2d"],
    displaylogo: false,
  };

  Plotly.newPlot("plotly-chart", traces, layout, config);
}

// Render on load
renderChart();
// Auto-expand results strip
setTimeout(() => toggleResults(), 500);
</script>
</body>
</html>
