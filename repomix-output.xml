done

echo ""
echo "Step 3: Rename function definitions..."
find . -name "*.py" -not -path "./.git/*" -not -path "./phase2/*" | while read pyfile; do
    sed -i \
        -e 's/def prism_barplot(/def plotter_barplot(/g' \
