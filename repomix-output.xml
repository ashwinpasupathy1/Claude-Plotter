  flex-direction: column;
  overflow: hidden;
  background: #F5F5F5;
  position: relative;
}

.chart-area-inner {
  flex: 1;
  padding: 16px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chart-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  gap: 10px;
}

.chart-placeholder-icon {
  font-size: 48px;
  opacity: 0.3;
}

.chart-placeholder p {
  font-size: 14px;
}

/* ── Config Panel ───────────────────────────────────────────────── */

.config-panel {
  width: 280px;
  flex-shrink: 0;
  background: #FAFAFA;
  border-left: 1px solid #E0E0E0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: width 0.2s ease;
}

.config-panel.collapsed {
  width: 0;
  overflow: hidden;
}

.config-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  border-bottom: 1px solid #E0E0E0;
  flex-shrink: 0;
}

.config-panel-header h2 {
  font-size: 13px;
  font-weight: 600;
  color: #222;
}

.config-panel-toggle {
  background: none;
  border: none;
