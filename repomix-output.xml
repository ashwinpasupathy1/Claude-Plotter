def test_event_subscribe_and_emit():
    bus = EventBus()
    calls = []
    bus.on(FILE_LOADED, lambda path="": calls.append(path))
    bus.emit(FILE_LOADED, path="/tmp/data.xlsx")
    assert calls == ["/tmp/data.xlsx"]

