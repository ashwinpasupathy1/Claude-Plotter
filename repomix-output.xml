        return json.dumps({"error": "Area chart needs at least 2 columns (X + one Y series)."})

    x_col = cols[0]
    y_cols = cols[1:]
    x_vals = pd.to_numeric(df[x_col], errors="coerce").tolist()

    traces = []
    for i, y_col in enumerate(y_cols):
        color = PRISM_PALETTE[i % len(PRISM_PALETTE)]
