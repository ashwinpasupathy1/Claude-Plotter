        canvas   = tk.Canvas(body_outer, bg="#ffffff", highlightthickness=0)
        scrollbar = ttk.Scrollbar(body_outer, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=scrollbar.set)
